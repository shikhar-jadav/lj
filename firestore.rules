
rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {

    function isSignedIn() {
      return request.auth != null;
    }

    // Simplified for prototype: Any signed-in partner can read/write shared collections
    match /userProfiles/{userId} {
      allow read, write: if isSignedIn();
      
      match /pointTransactions/{transactionId} {
        allow read, write: if isSignedIn();
      }
    }

    match /galleryImages/{imageId} {
      allow read, write: if isSignedIn();
    }

    match /diaryEntries/{diaryEntryId} {
      allow read, write: if isSignedIn();
    }

    match /tasks/{taskId} {
      allow read, write: if isSignedIn();
    }

    match /secretMessages/{messageId} {
      allow read, write: if isSignedIn();
    }

    match /dailyQuestions/{questionId} {
      allow read: if isSignedIn();
      allow write: if false;

      match /answers/{userId} {
        allow read, write: if isSignedIn();
      }
    }

    match /appMetadata/{document=**} {
      allow read, write: if isSignedIn();
    }
  }
}
